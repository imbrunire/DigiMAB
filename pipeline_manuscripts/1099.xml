          <mods:identifier type="managementId">05.1099</mods:identifier>
          <mods:titleInfo>
            <mods:title>Lettera di Henry Sewell Stokes a Mrs Laura Price</mods:title>
          </mods:titleInfo>
          <mods:abstract>Henry Sewell Stokes scrive da Bodmin a Mrs Laura Price il 25 febbraio 1878. Ringrazia la destinataria per l'invio di un'opera su Campanella, parte della quale era stata portata dal Governatore Mawe Charles, promettendo di restituirla in tempo. Chiede se debba inviare a prendere un volume. Ringrazia anche per l'invio di alcuni giornali, menzionando occasionalmente quello di Newlyn. Si scusa per la fretta dovuta alla presenza di Mrs Jesty.</mods:abstract>
          <mods:name type="personal">
            <mods:namePart>Stokes, Henry Sewell</mods:namePart>
            <mods:namePart type="date">1808-1895</mods:namePart>
            <mods:role>
              <mods:roleTerm type="text">author</mods:roleTerm>
            </mods:role>
          </mods:name>
          <mods:name type="personal">
            <mods:namePart>Price, Laura</mods:namePart>
            <mods:role>
              <mods:roleTerm type="text">recipient</mods:roleTerm>
            </mods:role>
          </mods:name>
          <mods:originInfo>
            <mods:dateCreated encoding="iso8601">1878-02-25</mods:dateCreated>
            <mods:place>
              <mods:placeTerm type="text">Bodmin</mods:placeTerm>
            </mods:place>
          </mods:originInfo>
          <mods:physicalDescription>
            <mods:form type="material">Cartaceo</mods:form>
            <mods:extent>c. 1</mods:extent>
            <mods:note type="condition">Buono</mods:note>
          </mods:physicalDescription>
          <mods:language>
            <mods:languageTerm type="code" authority="iso639-3">eng</mods:languageTerm>
          </mods:language>
          <mods:note type="content">Lettera manoscritta in corsivo inglese ottocentesco. Carta piegata a metà formando due pagine. Il retro presenta testo molto sbiadito e quasi completamente illeggibile.</mods:note>
          <mods:recordInfo>
            <mods:recordContentSource>ARCHIVIO-001</mods:recordContentSource>
          </mods:recordInfo>
        </mods:mods>
      </mets:xmlData>
    </mets:mdWrap>
  </mets:dmdSec>
